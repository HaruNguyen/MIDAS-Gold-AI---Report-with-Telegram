# Doi ten file nay thanh ".env" va dien gia tri thuc te truoc khi chay

# Khoa bi mat dung de xac thuc request tu EA goi len /api/report
# (phai khop voi Report_ApiKey khai bao trong ReportModule.mqh)
REPORT_API_KEY=CHANGE_ME_SECRET_KEY

# Lay tu @BotFather sau khi tao bot Telegram moi
TELEGRAM_BOT_TOKEN=

# Chat ID nhan canh bao / digest (chat ca nhan, hoac group id dang -100xxxxxxxxxx)
TELEGRAM_CHAT_ID=

# Database (mac dinh dung SQLite cho prototype; doi sang Postgres khi scale)
DATABASE_URL=sqlite:///./midas_report.db

# Nguong phan loai suc khoe bo lenh
ORDERS_WATCH_THRESHOLD=15
ORDERS_CRITICAL_THRESHOLD=26
DRAWDOWN_WARNING_PCT=15
DRAWDOWN_CRITICAL_PCT=30
MARGIN_LEVEL_WARNING=200

# Hoa hong IB uoc tinh ($/lot) — dung de tinh doanh thu trong digest
IB_RATE_USD_PER_LOT=5.0

# Gio gui digest hang ngay (24h, theo gio server)
DAILY_DIGEST_HOUR=8
DAILY_DIGEST_MINUTE=0
